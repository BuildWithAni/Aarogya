# ──────────────────────────────────────────────
# Aarogyam Backend Environment Configuration
# ──────────────────────────────────────────────

# Server Port
PORT=5000

# JWT Secret Key (change this to a long random string in production!)
JWT_SECRET=change_this_to_a_long_random_string

# Staff Auth Key for doctor/admin login
STAFF_AUTH_KEY=change_this_to_a_strong_key

# Database URL
# SQLite (development): file:./dev.db
# PostgreSQL (production): postgresql://aarogya:password@localhost:5432/aarogya_db
DATABASE_URL=file:./dev.db

# Firebase Service Account JSON (paste the entire JSON on one line)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"..."}

# Cloudinary URL for file uploads
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Node environment
NODE_ENV=development
